{
  "name": "tourney",
  "version": "0.40.0",
  "description": "The next level of tournament management.",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": "22"
  },
  "scripts": {
    "clean": "git clean -xdf node_modules",
    "create:users": "turbo run create --filter=@tourney/user-creator",
    "fill:tournament": "cd ./apps/user-creator && bun run fill:tournament",
    "start:docs": "vitepress preview docs",
    "start:admin": "cd ./apps/admin && bun .output/server/index.mjs",
    "start:viewer": "cd ./apps/viewer && bun .output/server/index.mjs",
    "start:www": "cd ./apps/www && bun .output/server/index.mjs",
    "start": "turbo run start",
    "build:docs": "vitepress build docs",
    "build:admin": "turbo run build --filter=@tourney/admin",
    "build:viewer": "turbo run build --filter=@tourney/viewer",
    "build:www": "turbo run build --filter=@tourney/www",
    "build": "turbo run build",
    "build:nocache": "turbo run build --force",
    "analyze:admin": "turbo run analyze --filter=@tourney/admin",
    "dev:admin": "turbo run dev --filter=@tourney/admin",
    "dev:viewer": "turbo run dev --filter=@tourney/viewer",
    "dev:www": "turbo run dev --filter=@tourney/www",
    "dev:core": "turbo run dev --filter=@tourney/core",
    "dev:docs": "vitepress dev docs",
    "dev": "turbo run dev",
    "dev:admin:host": "turbo run dev --filter=@tourney/admin -- --host",
    "dev:viewer:host": "turbo run dev --filter=@tourney/viewer -- --host",
    "dev:www:host": "turbo run dev --filter=@tourney/www -- --host",
    "generate-pwa-assets": "pnpm --filter=@tourney/viewer run generate-pwa-assets",
    "start:supabase": "cd ./apps/api/supabase && bunx supabase start",
    "stop:supabase": "cd ./apps/api/supabase && bunx supabase stop",
    "types:supabase": "cd ./apps/api/supabase && bunx supabase gen types --lang=typescript --local > ../../../packages/types/src/database.types.ts",
    "schema:supabase": "cd ./apps/api/supabase && bunx supabase db diff -f --local",
    "format": "turbo run format",
    "format:write": "turbo run format:write",
    "release": "HUSKY=0 semantic-release",
    "prepare": "husky"
  },
  "catalogs": {
    "framework": {
      "@nuxtjs/device": "^4.0.0",
      "@vueuse/core": "^14.2.1",
      "@vueuse/nuxt": "^14.2.1",
      "nuxt": "4.3.1",
      "vue": "3.5.29",
      "vue-router": "5.0.3"
    },
    "ui": {
      "@iconify-json/heroicons": "^1.2.3",
      "@iconify-json/svg-spinners": "^1.2.4",
      "@nuxt/fonts": "^0.14.0",
      "@nuxt/image": "^2.0.0",
      "@nuxt/ui": "^4.0.0",
      "@nuxtjs/mdc": "^0.20.1",
      "tailwindcss": "^4.0.0"
    },
    "data": {
      "@nuxtjs/supabase": "^2.0.4",
      "@supabase/supabase-js": "^2.97.0"
    },
    "ai": {
      "@ai-sdk/openai": "^3.0.39",
      "@ai-sdk/vue": "^3.0.112",
      "ai": "^6.0.112"
    },
    "avatars": {
      "@dicebear/collection": "^9.3.2",
      "@dicebear/core": "^9.3.2"
    },
    "flow": {
      "@vue-flow/background": "^1.3.2",
      "@vue-flow/controls": "^1.1.3",
      "@vue-flow/core": "^1.48.2",
      "@vue-flow/minimap": "^1.5.4"
    },
    "validation": {
      "zod": "^3.25.67"
    },
    "viewer-tooling": {
      "@types/k6": "^1.6.0",
      "@vite-pwa/assets-generator": "^1.0.0",
      "@vite-pwa/nuxt": "1.1.1",
      "handlebars": "^4.7.8"
    },
    "release": {
      "@semantic-release/changelog": "^6.0.3",
      "@semantic-release/commit-analyzer": "^13.0.1",
      "@semantic-release/git": "^10.0.1",
      "@semantic-release/github": "^12.0.6",
      "@semantic-release/npm": "^13.1.5",
      "@semantic-release/release-notes-generator": "^14.1.0",
      "semantic-release": "^25.0.3"
    },
    "repo-tooling": {
      "husky": "^9.1.7",
      "lint-staged": "^16.3.1",
      "turbo": "^2.8.12",
      "vitepress": "^1.6.4"
    },
    "formatting": {
      "prettier": "^3.8.1",
      "prettier-plugin-tailwindcss": "^0.7.2"
    },
    "typescript": {
      "@types/node": "24.0.4",
      "typescript": "^5.9.2"
    }
  },
  "devDependencies": {
    "@semantic-release/changelog": "catalog:release",
    "@semantic-release/commit-analyzer": "catalog:release",
    "@semantic-release/git": "catalog:release",
    "@semantic-release/github": "catalog:release",
    "@semantic-release/npm": "catalog:release",
    "@semantic-release/release-notes-generator": "catalog:release",
    "husky": "catalog:repo-tooling",
    "lint-staged": "catalog:repo-tooling",
    "prettier": "catalog:formatting",
    "prettier-plugin-tailwindcss": "catalog:formatting",
    "semantic-release": "catalog:release",
    "turbo": "catalog:repo-tooling",
    "vitepress": "catalog:repo-tooling"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "prettier . --write"
    ]
  },
  "author": "Dino Kupinic",
  "license": "MIT"
}
