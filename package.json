{
  "name": "tourney",
  "version": "0.31.0",
  "description": "The next level of tournament management.",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "clean": "git clean -xdf node_modules",
    "create:users": "turbo run create --filter=@tourney/user-creator",
    "install:browsers": "bunx puppeteer browsers install",
    "start:docs": "vitepress preview docs",
    "start:admin": "cd ./apps/admin && bun .output/server/index.mjs",
    "start:viewer": "cd ./apps/viewer && bun .output/server/index.mjs",
    "start": "turbo run start",
    "build:docs": "vitepress build docs",
    "build:admin": "turbo run build --filter=@tourney/admin",
    "build:viewer": "turbo run build --filter=@tourney/viewer",
    "build": "turbo run build",
    "build:nocache": "turbo run build --force",
    "analyze:admin": "turbo run analyze --filter=@tourney/admin",
    "dev:admin": "turbo run dev --filter=@tourney/admin",
    "dev:viewer": "turbo run dev --filter=@tourney/viewer",
    "dev:core": "turbo run dev --filter=@tourney/core",
    "dev:docs": "vitepress dev docs",
    "dev": "turbo run dev",
    "dev:admin:host": "turbo run dev --filter=@tourney/admin -- --host",
    "dev:viewer:host": "turbo run dev --filter=@tourney/viewer -- --host",
    "generate-pwa-assets": "pnpm --filter=@tourney/viewer run generate-pwa-assets",
    "start:supabase": "cd ./apps/api/supabase && bunx supabase start",
    "stop:supabase": "cd ./apps/api/supabase && bunx supabase stop",
    "types:supabase": "cd ./apps/api/supabase && bunx supabase gen types --lang=typescript --local > ../../../packages/types/src/database.types.ts",
    "schema:supabase": "cd ./apps/api/supabase && bunx supabase db diff -f --local",
    "format": "turbo run format",
    "format:write": "turbo run format:write",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "keywords": [
    "tournaments",
    "nuxt",
    "vue"
  ],
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "semantic-release": "^25.0.3",
    "turbo": "^2.8.12",
    "vitepress": "^1.6.4"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "prettier . --write"
    ]
  },
  "author": "Dino Kupinic",
  "license": "MIT"
}
