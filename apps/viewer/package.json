{
  "name": "@tourney/viewer",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "analyze": "nuxi analyze",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "start": "PORT=3001 bun run ./.output/server/index.mjs ",
    "generate-pwa-assets": "pwa-assets-generator --preset minimal-2023 public/logo.svg",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "check-types": "vue-tsc --noEmit"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@iconify-json/heroicons": "catalog:ui",
    "@iconify-json/svg-spinners": "catalog:ui",
    "@nuxtjs/device": "catalog:framework",
    "@nuxtjs/supabase": "catalog:data",
    "@supabase/supabase-js": "catalog:data",
    "@vite-pwa/nuxt": "catalog:viewer-tooling",
    "@vue-flow/background": "catalog:flow",
    "@vue-flow/controls": "catalog:flow",
    "@vue-flow/core": "catalog:flow",
    "@vue-flow/minimap": "catalog:flow",
    "@vueuse/core": "catalog:framework",
    "@vueuse/nuxt": "catalog:framework",
    "handlebars": "catalog:viewer-tooling",
    "nuxt": "catalog:framework",
    "vue": "catalog:framework",
    "vue-router": "catalog:framework",
    "zod": "catalog:validation"
  },
  "devDependencies": {
    "@tourney/types": "workspace:*",
    "@types/k6": "catalog:viewer-tooling",
    "@vite-pwa/assets-generator": "catalog:viewer-tooling"
  }
}
